// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views", "omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String?  @unique
  lastName     String?  @default("lastName")
  firstName    String?  @default("firstName")
  passwordHash String?  @default("hash")
  passwordSalt String?  @default("salt")
  created_at   DateTime @default(now()) @db.Timestamptz(3)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(3)
}
